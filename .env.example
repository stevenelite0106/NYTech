# Postgres (Vercel Postgres / Neon)
POSTGRES_URL=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Resend
RESEND_API_KEY=
RESEND_FROM="Space of Mind <studio@spaceofmind.app>"

# Cron job protection (random string; Vercel sets this header on its cron requests)
CRON_SECRET=

# Delivery delay in days. Brief says 10.
DELIVERY_DELAY_DAYS=10

# Event label embedded in the email (e.g. "NY Tech Week")
EVENT_NAME="NY Tech Week"

# Public URL of the deployed app (used in email CTA)
NEXT_PUBLIC_APP_URL=https://spaceofmind.app
NEXT_PUBLIC_BOOTH_QUESTION_COUNT=1