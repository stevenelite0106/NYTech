# ─────────────────────────────────────────────────────────────────────────
# Space of Mind — environment variable template
#
# Copy to .env.local for local dev. For Vercel production, set the same
# variables in Project → Settings → Environment Variables (use Production
# scope unless noted otherwise).
#
# Three groups below:
#   1. Required — must be set for the booth to function
#   2. Optional — features that degrade gracefully if unset
#   3. Local-dev only — DO NOT set in production
# ─────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════
# 1. REQUIRED
# ═════════════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────────────
# Postgres connection string. Auto-injected by Vercel if you attach a
# Vercel Postgres or Neon store. Set manually for any other provider.
POSTGRES_URL=

# ─── Blob storage ────────────────────────────────────────────────────────
# Auto-injected by Vercel when you attach a Blob store. Set manually if
# running locally with a separate token.
BLOB_READ_WRITE_TOKEN=

# ─── Email delivery (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=
# Must be a sender on a domain verified in Resend's dashboard.
RESEND_FROM="Space of Mind <studio@spaceofmind.app>"

# ─── Cron auth ───────────────────────────────────────────────────────────
# Long random bearer token. Generate fresh per environment:
#   openssl rand -hex 32
# /api/cron/deliver rejects requests without a matching Bearer header.
CRON_SECRET=

# ─── Public URL ──────────────────────────────────────────────────────────
# Where email CTA buttons land. MUST be your real production URL — no
# trailing slash. For Vercel previews, set to the preview URL.
NEXT_PUBLIC_APP_URL=https://spaceofmind.app

# ─── Delivery scheduling ─────────────────────────────────────────────────
# Production: 10 days from recording to email send.
DELIVERY_DELAY_DAYS=10

# Event label shown in the delivered email's context line.
EVENT_NAME="NY Tech Week"

# ─── OpenAI (Whisper transcription + GPT analysis) ───────────────────────
# Needs gpt-4o + gpt-4o-mini access. ~$0.01–0.02 per booth visit.
OPENAI_API_KEY=


# ═════════════════════════════════════════════════════════════════════════
# 2. OPTIONAL — features that degrade gracefully if unset
# ═════════════════════════════════════════════════════════════════════════

# ─── Brain map (TRIBE v2 on RunPod Serverless) ───────────────────────────
# Both must be set together. If either is missing, the analyze pipeline
# skips the brain stage and the Confirmation/email render without the
# brain section. The rest of the analysis is unaffected.
#
# Set to true to skip RunPod even when keys are present — use when the booth
# is timing out on "Mapping cortical activations" (GPU often exceeds Vercel's
# 300s limit on cold workers). Processing still shows the brain step briefly
# then continues with brain_map=null.
SKIP_BRAIN_RENDER=true
#
# Research / non-commercial use only — TRIBE v2 is CC BY-NC.
# See brain-service/README.md for endpoint setup.
RUNPOD_ENDPOINT_ID=
RUNPOD_API_KEY=


# ═════════════════════════════════════════════════════════════════════════
# 3. LOCAL-DEV ONLY — DO NOT set in production
# ═════════════════════════════════════════════════════════════════════════

# Truncates the booth flow to N questions instead of 5. Useful for
# iterating without sitting through the full 4–6 min flow each cycle.
# If this leaks to Vercel production, attendees only get N questions.
# Leave commented out (or unset) in any deployed environment.
#
# NEXT_PUBLIC_ prefix → baked into the client bundle at build time, so
# `vercel env pull` would propagate it. Keep it local-only.
NEXT_PUBLIC_BOOTH_QUESTION_COUNT=1

# Testing shortcut that overrides DELIVERY_DELAY_DAYS with minutes for
# faster email-delivery testing. If set in production, emails ship in
# minutes instead of 10 days. Confirm absent in Vercel prod scope.
#
# DELIVERY_DELAY_MINUTES=2
